# Database — Railway injects this automatically when you add PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT secret — generate a strong random string
SECRET_KEY=change-me-to-a-long-random-string

# Token expiry in hours (default: 72)
TOKEN_EXPIRE_HOURS=72

# Master key for tenant provisioning (POST /tenants)
MASTER_API_KEY=change-me-to-a-strong-key

# CORS — comma-separated origins (use * for dev, lock down for prod)
CORS_ORIGINS=*

# Media storage directory (Railway volume mount point)
MEDIA_DIR=/app/media
